#!/usr/bin/env bash
# zz-name: update
# zz-summary: Fast-forward the installer repo and run check.
# zz-usage: zz update [check options]
set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

main() {
  local dry_run=0
  if [[ "${1:-}" == "--dry-run" ]]; then
    dry_run=1
    shift
  fi

  git -C "$ROOT_DIR" update-index -q --refresh
  if [[ -n "$(git -C "$ROOT_DIR" status --porcelain)" ]]; then
    printf 'Refusing to update because the installer worktree is dirty.\n' >&2
    printf 'Commit, stash, or remove local changes before running zz update.\n' >&2
    return 1
  fi

  local upstream
  upstream="$(git -C "$ROOT_DIR" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
  [[ -n "$upstream" ]] || {
    printf 'Refusing to update because the current branch has no upstream.\n' >&2
    return 1
  }

  if [[ "$dry_run" -eq 1 ]]; then
    printf 'DRY-RUN: git fetch --tags --prune\n'
    printf 'DRY-RUN: git merge --ff-only %s\n' "$upstream"
    printf 'DRY-RUN: zz check %s\n' "$*"
    return 0
  fi

  git -C "$ROOT_DIR" fetch --tags --prune
  git -C "$ROOT_DIR" merge --ff-only "$upstream"
  exec "$ROOT_DIR/install.sh" check "$@"
}

main "$@"
