#!/usr/bin/env bash
set -Eeuo pipefail

find_agent() {
  local candidate
  for candidate in \
    /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 \
    /usr/libexec/polkit-gnome-authentication-agent-1 \
    polkit-gnome-authentication-agent-1
  do
    if [[ "$candidate" == /* ]]; then
      [[ -x "$candidate" ]] && printf '%s\n' "$candidate" && return 0
      continue
    fi
    if command -v "$candidate" >/dev/null 2>&1; then
      command -v "$candidate"
      return 0
    fi
  done
  return 1
}

main() {
  local agent
  if ! agent="$(find_agent)"; then
    printf 'noctalia-polkit-agent: no polkit-gnome agent found\n' >&2
    exit 0
  fi

  exec "$agent"
}

main "$@"
