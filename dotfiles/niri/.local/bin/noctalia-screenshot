#!/usr/bin/env bash
set -Eeuo pipefail

[[ -f "$HOME/.config/user-dirs.dirs" ]] && source "$HOME/.config/user-dirs.dirs"
output_dir="${XDG_PICTURES_DIR:-$HOME/Pictures}/Screenshots"
mkdir -p "$output_dir"

selection="$(slurp 2>/dev/null)" || exit 0
[[ -n "$selection" ]] || exit 0

file_path="$output_dir/Screenshot from $(date +'%Y-%m-%d %H-%M-%S').png"
grim -g "$selection" "$file_path"
wl-copy <"$file_path"

if command -v satty >/dev/null 2>&1; then
  exec satty --filename "$file_path" \
    --output-filename "$file_path" \
    --actions-on-enter save-to-clipboard \
    --save-after-copy \
    --copy-command 'wl-copy'
fi

if command -v swappy >/dev/null 2>&1; then
  exec swappy -f "$file_path"
fi

printf '%s\n' "$file_path"
